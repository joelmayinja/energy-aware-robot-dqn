# Byte-compiled / cache
__pycache__/
*.py[cod]
*.pyc

# Virtual environments
venv/
env/
.venv/

# Jupyter
.ipynb_checkpoints/

# Data (datasets can be large — don't commit raw data to git)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Trained model weights (can be large too)
models/*.pt
models/*.pth
models/*.onnx
!models/.gitkeep

# OS junk
.DS_Store
Thumbs.db

# Editor settings
.vscode/
.idea/

# Logs
*.log
